# NexusFTP Production Environment Configuration
# Copy to .env and fill in values

# Server Configuration
NODE_ENV=production
PORT=3434
JWT_SECRET=generate-a-random-secret-with-openssl-rand-base64-32
CORS_ORIGINS=https://ifpt.xus.me:3434,http://ifpt.xus.me:3434,http://localhost:3434

# FTP/SFTP Configuration
FTP_TIMEOUT=30000
SFTP_TIMEOUT=30000

# Storage
TRASH_RETENTION_DAYS=30
DATA_DIR=/app/data
LOG_DIR=/app/logs
LOG_LEVEL=info
